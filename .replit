modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[userenv]

[userenv.shared]
PORT = "5000"
NODE_ENV = "production"
ADMIN_EMAIL = "admin@broqinsta.com"
RATE_LIMIT_WINDOW_MS = "3600000"
RATE_LIMIT_MAX_REQUESTS = "10"
RAPIDAPI_HOST = "instagram-downloader-download-instagram-stories-videos4.p.rapidapi.com"
API_ENDPOINT = "https://instagram-downloader-download-instagram-stories-videos4.p.rapidapi.com/convert"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
