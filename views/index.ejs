<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BroqInsta - Premium Instagram Video & Reels Downloader | HD Quality</title>
    <meta name="description"
        content="Fast, free, and secure Instagram downloader. Save reels, videos, and photos in HD quality instantly. No login required. Trusted by thousands worldwide.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= siteUrl %>">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5905358857319449"
        crossorigin="anonymous"></script>

    <meta property="og:type" content="website">
    <meta property="og:title" content="BroqInsta - Professional Instagram Downloader">
    <meta property="og:description" content="Download Instagram videos in seconds. Fast, HD, and secure.">
    <meta property="og:image" content="<%= siteUrl %>/images/preview.png">
    <meta property="og:url" content="<%= siteUrl %>">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="icon" type="image/png" href="/images/logo.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="preconnect" href="https://cdn.tailwindcss.com">

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "BroqInsta",
        "url": "<%= siteUrl %>",
        "description": "Fast, free, and secure Instagram downloader. Save reels, videos, and photos in HD quality instantly."
    }
    </script>

    <style>
        .hero-title {
            font-size: 64px;
            letter-spacing: -0.04em;
        }

        .text-gradient-hero {
            background: linear-gradient(135deg, #1F2937 0%, #4B5563 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            background: #10B981;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            animation: pulse-ring 2s infinite;
        }

        @keyframes pulse-ring {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            }

            70% {
                transform: scale(1);
                box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
            }

            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
            }
        }
    </style>
    <script>
        async function injectGlobalScripts() {
            try {
                const res = await fetch('/api/ads');
                const data = await res.json();
                if (data.success && data.header) {
                    const temp = document.createElement('div');
                    temp.innerHTML = data.header;
                    Array.from(temp.childNodes).forEach(node => {
                        if (node.nodeName === 'SCRIPT') {
                            const script = document.createElement('script');
                            Array.from(node.attributes).forEach(attr => script.setAttribute(attr.name, attr.value));
                            script.innerHTML = node.innerHTML;
                            document.head.appendChild(script);
                        } else {
                            document.head.appendChild(node.cloneNode(true));
                        }
                    });
                }
            } catch (e) { }
        }
        injectGlobalScripts();
    </script>
</head>

<body class="bg-[#FAFBFC] min-h-screen flex flex-col">
    <div class="hero-background">
        <div class="gradient-orb orb-1"></div>
        <div class="gradient-orb orb-2"></div>
        <div class="gradient-orb orb-3"></div>
    </div>

    <%- include('partials/header') %>

    <main class="flex-grow">
        <section id="top" class="pt-20 pb-32 px-4 text-center">
            <div class="container mx-auto max-w-4xl stagger-in">
