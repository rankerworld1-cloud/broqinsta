                            <p class="text-gray-500 font-medium line-clamp-3 leading-relaxed"><%= post.excerpt || '' %></p>
                        </div>
                        <div class="pt-8 mt-8 border-t border-gray-50 flex items-center text-xs font-black uppercase tracking-widest text-gray-900 group-hover:translate-x-2 transition-transform">
                            Read More <span class="ml-2">&rarr;</span>
